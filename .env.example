# Ward — Environment Variables
# Copy this file to .env.local (local dev) and set the same variable in your
# hosting provider's dashboard (production).

# Alchemy API key — REQUIRED for chain access, token balances, and NFTs.
#
# Server-only: this is NEVER exposed to the browser. All Alchemy traffic is
# proxied through the /api/rpc and /api/nft route handlers, which read this
# value server-side. Do NOT prefix it with NEXT_PUBLIC_.
#
# Get one at https://dashboard.alchemy.com — enable the Sepolia testnets you
# use (Eth, Base, Optimism, Arbitrum, Polygon Amoy) plus Eth Mainnet for ENS.
ALCHEMY_KEY=
